# =============================================================================
# Unity 6 (6000.x)
# =============================================================================

# Generated folders — never commit these
MothionCapture/Library/
MothionCapture/Temp/
MothionCapture/Logs/
MothionCapture/obj/
MothionCapture/Build/
MothionCapture/Builds/

# User-specific editor state — differs per machine
MothionCapture/UserSettings/

# IDE project files generated by Unity
MothionCapture/*.sln
MothionCapture/*.csproj

# Unity-generated asset files (binary / intermediate)
MothionCapture/*.unitypackage
MothionCapture/*.apk
MothionCapture/*.aab
MothionCapture/*.exe

# APK/AAB splits
MothionCapture/Bundles/

# Crashlytics generated file
MothionCapture/crashlytics-build.properties

# =============================================================================
# Python (pose_estimation)
# =============================================================================

pose_estimation/__pycache__/
pose_estimation/**/__pycache__/
pose_estimation/*.pyc
pose_estimation/*.pyo
pose_estimation/*.pyd
pose_estimation/.venv/

# YOLO model weights — large binary, download on first run
pose_estimation/*.pt
pose_estimation/*.onnx

# =============================================================================
# uv (Python package manager)
# =============================================================================

.python-version

# =============================================================================
# OS
# =============================================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

